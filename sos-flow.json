    {
        "id": "sos_func_format1",
        "type": "function",
        "z": "sos_flow_tab",
        "name": "Format Alerts Response",
        "func": "msg.statusCode = 200;\nmsg.payload = {\n    success: true,\n    alerts: msg.payload\n};\nreturn msg;",

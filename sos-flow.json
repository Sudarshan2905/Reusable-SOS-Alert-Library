    {
        "id": "sos_http_in1",
        "type": "http in",
        "z": "sos_flow_tab",
        "name": "GET /sos-alerts",
        "url": "/sos-alerts",
        "method": "get",
        "upload": false,
        "swaggerDoc": "",

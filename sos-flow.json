                "sos_func_validate2"
            ]
        ]
    },
    {
        "id": "sos_func_validate2",
        "type": "function",
        "z": "sos_flow_tab",
        "name": "Validate & Prepare Insert",
        "func": "var body = msg.payload || {};\nvar alert = body.alert;\nvar machineid = (body.machineid === undefined || body.machineid === null || body.machineid === '') ? null : body.machineid;\n\nif (!alert || alert.toString().trim() === '') {\n    var errMsg = { ...msg };\n    errMsg.statusCode = 400;\n    errMsg.payload = {\n        success: false,\n        message: \"Alert is required.\"\n    };\n    return [null, errMsg];\n}\n\nmsg.topic = \"INSERT INTO sosalert_history (machineid, alert) VALUES (?, ?);\";\nmsg.payload = [machineid, alert];\nreturn [msg, null];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 630,
        "y": 260,
        "wires": [
            [
                "sos_mysql2"
            ],

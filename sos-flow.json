        "y": 100,
        "wires": [
            [
                "sos_func_prep1"
            ]
        ]
    },
    {
        "id": "sos_func_prep1",
        "type": "function",
        "z": "sos_flow_tab",
        "name": "Prepare Alerts Query",
        "func": "msg.topic = \"SELECT DISTINCT alert FROM sosalerts WHERE alert IS NOT NULL ORDER BY alert ASC;\";\nmsg.payload = [];\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
